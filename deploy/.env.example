# Скопируйте в .env и подставьте IP/домен сервера
RUC_HTTP_PORT=80
RUC_CORS_ALLOWED_ORIGINS=http://192.168.1.100,http://ruc-connect.example.ru

# Опционально: peer ID для демо-адресной книги
RUC_DEMO_PEER_FIRST=111222333
RUC_DEMO_PEER_SECOND=444555666

# Если поднят engine relay на этом же сервере — укажите его IP
RUC_ENGINE_ID_SERVER=192.168.1.100:21116
RUC_ENGINE_RELAY=192.168.1.100:21117
